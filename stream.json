{
    "type": "pages",
    "headline": "Input Plugin Test",
    "template": {
        "enumerate": false,
        "type": "button",
        "layout": "0,0,3,3"
    },
    "items": [
        {
            "icon": "keyboard",
            "label": "Enter URL",
            "action": "input",
            "input": {
                "placeholder": "Enter URL here",
                "id": "url_input"
            }
        },
        {
            "icon": "navigate",
            "label": "Go to URL",
            "action": "content:request:interaction:http://msx.benzac.de/services/input.php?input=${url_input}&type=default|default|en|Navigate to URL|||Click on {ico:msx-white:done} to submit input@http://msx.benzac.de/interaction/input.html"
        }
    ]
}
